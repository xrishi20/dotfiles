{
   "ui_font_family": "Inter",
   "buffer_line_height": "comfortable",
   "buffer_font_weight": 400.0,
   "disable_ai": true,
   "session": {
      "trust_all_worktrees": true,
   },
   "telemetry": {
      "diagnostics": true,
      "metrics": false,
   },
   "terminal": {
      "font_size": 16.0,
      "font_family": "JetBrainsMono Nerd Font Mono",
      "font_fallbacks": [
         "JetBrainsMono NF",
         "Consolas",
         "Courier New",
         "monospace",
      ],
      "cursor_shape": "bar",
   },
   "base_keymap": "VSCode",
   "minimap": {
      "show": "never",
   },
   "cursor_shape": "bar",
   "cursor_blink": true,
   "buffer_font_fallbacks": [
      "JetBrainsMono NF",
      "Consolas",
      "Courier New",
      "monospace",
   ],
   "buffer_font_family": "Operator Mono Lig",
   "file_types": {
      "twig": ["*.twig", "*.twig"],
      "typescriptreact": ["*.tsx", "*.tsx"],
   },
   "colorize_brackets": true,
   "linked_edits": true,
   "use_on_type_format": true,
   "show_whitespaces": "none",
   "soft_wrap": "editor_width",
   "tab_size": 3,
   "icon_theme": "Material Icon Theme",
   "ui_font_size": 16,
   "buffer_font_size": 18.0,
   "theme": {
      "mode": "dark",
      "light": "One Light",
      "dark": "Vesper Blur",
   },
}
