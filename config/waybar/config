{
    "layer": "bottom",
    "position": "bottom",
    "margin-bottom": 8,
    "margin-left": 8,
    "margin-right": 8,
    "modules-left": [
        "clock",
        "clock#date"
    ],
    "modules-center": [
        "hyprland/workspaces"
    ],
    "modules-right": [
        "network",
        "pulseaudio",
        "backlight",
        "temperature",
        "battery",
        "tray"
    ],
    "tray": {
        "spacing": 10
    },
    "clock": {
        "format": "ΎΡ║  {:%I:%M %p}"
    },
    "clock#date": {
        "format": "≤░ρ▓  {:%A, %d %B}"
    },
    "backlight": {
        "format": "{icon}  {percent}%",
        "format-icons": [
            "≤░Δη",
            "≤░Δθ",
            "≤░Δι"
        ],
        "on-scroll-up": "brightnessctl set 1%+",
        "on-scroll-down": "brightnessctl set 1%-",
        "min-length": 4,
        "interval": 2
    },
    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-bluetooth": "≤░Γ▒  {volume}%",
        "format-muted": "≤░ΨΒ",
        "scroll-step": 1,
        "on-click": "pavucontrol",
        "ignored-sinks": [
            "Easy Effects Sink"
        ],
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΨΡ",
            "headset": "≤░ΜΟ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": [
                "ΎΑπ",
                "ΎΑρ"
            ]
        }
    },
    "network": {
        "format": "{ifname}",
        "format-wifi": "{icon}   {essid}",
        "format-ethernet": "≤░ΙΑ   {ipaddr}/{cidr}",
        "format-disconnected": "≤░νφ   disconnected",
        "max-length": 50,
        "format-icons": [
            "≤░νψ",
            "≤░νθ",
            "≤░νλ",
            "≤░νξ",
            "≤░νρ"
        ]
    },
    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "format-icons": {
            "active": "≤░χψ",
            "default": "≤░χψ"
        }
    },
    "battery": {
        "states": {
            "good": 55,
            "warning": 30,
            "critical": 20
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "ΎΔπ  {capacity}%",
        "format-plugged": "≤░ΓΕ  {capacity}%",
        "format-alt": "{icon}  {time}",
        "format-full": "≤▒θλ {capacity}%",
        "format-icons": [
            "≤░Β║",
            "≤░Β╗",
            "≤░Β╝",
            "≤░Β╜",
            "≤░Β╛",
            "≤░Β┐",
            "≤░ΓΑ",
            "≤░ΓΒ",
            "≤░ΓΓ",
            "≤▒θλ"
        ],
        "interval": 2
    },
    "temperature": {
        "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "format": "{icon}  {temperatureC}┬░C",
        "format-icons": [
            "ΎΜΛ",
            "Ό╝τ",
            "Ό╝ς"
        ],
        "tooltip": true,
        "on-click": "kitty --start-as=fullscreen --title all_is_kitty sh -c 'htop'",
        "interval": 2
    }
}
